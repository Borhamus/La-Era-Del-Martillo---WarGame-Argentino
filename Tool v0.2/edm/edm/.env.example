# ============================================================
# .env.example — La Era del Martillo V2
# Copiá este archivo como .env y completá los valores
# ============================================================

# Base de datos
# Para desarrollo local: apuntar a tu PostgreSQL
# Para Docker: usar el nombre del servicio "db" (ya configurado en docker-compose.yml)
DATABASE_URL="postgresql://postgres:edm_password_2025@localhost:5432/era_del_martillo"

# Contraseña de la base de datos (usada también en docker-compose)
DB_PASSWORD="edm_password_2025"

# NextAuth — OBLIGATORIO en producción
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="REEMPLAZAR-con-secreto-generado"

# URL base de la app (cambiar a la IP de tu máquina para acceso desde red local)
# Ejemplos:
#   Desarrollo local:  http://localhost:3000
#   Red local:         http://192.168.1.100:3000
NEXTAUTH_URL="http://localhost:3000"

# Datos del admin inicial (creado con `npx prisma db seed`)
ADMIN_EMAIL="admin@eradelMartillo.com"
ADMIN_PASSWORD="cambiar-esto-antes-de-compartir"
